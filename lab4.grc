    minoutbuf: '0'
    test_mode: 'False'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [880, 196.0]
    rotation: 0
    state: enabled
- name: import_0
  id: import
  parameters:
